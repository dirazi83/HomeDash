# HomeDash environment variables
# Copy to .env and set your own values

SECRET_KEY=django-insecure-change-me-in-production
DEBUG=False

# PostgreSQL
DB_NAME=homedash
DB_USER=admin
DB_PASSWORD=admin

# Admin user created on first run
ADMIN_USER=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@homedash.local

# App port (default 3033)
PORT=3033
